# =============================================================================
# Toyhana — production environment
#
# Копировать в .env и заполнить:
#   cp .env.example .env
# =============================================================================

# ---- БД ----
DB_NAME=toyhana
DB_USER=toyhana_user
# Сгенерировать сильный пароль:
#   openssl rand -hex 24
DB_PASSWORD=CHANGE_ME_strong_random_password

# ---- JWT ----
# 32+ случайных символа. Сгенерировать:
#   openssl rand -hex 32
JWT_SECRET=CHANGE_ME_64_hex_chars

# ---- Telegram (опционально) ----
# Уведомления админу о новых заявках. Если пусто — функция отключена.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Mobizon SMS (для production) ----
# В dev (TOYHANA_ENV=dev) код всегда '0000', реальные SMS не шлются.
# В prod — реальные SMS через https://mobizon.kz.
# Получить ключ: ЛК Mobizon -> API -> создать токен
MOBIZON_API_KEY=
# Подпись отправителя. Если зарегистрирована у операторов — например 'TOYHANA'.
# Если пусто — Mobizon использует общую подпись (типа MOBINFO).
MOBIZON_SENDER=

# ---- 2GIS API (опционально, для будущего автокомплита адресов) ----
TWOGIS_API_KEY=
