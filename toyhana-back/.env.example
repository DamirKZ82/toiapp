# Скопируй этот файл в .env и заполни значения.
# .env в репозиторий не коммитится.

# Окружение: dev | stage | prod
TOYHANA_ENV=dev

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=toyhana
DB_USER=toyhana_user
DB_PASSWORD=change_me

# JWT — сгенерируй командой: openssl rand -hex 32
JWT_SECRET=change_me_to_a_long_random_hex_string

# Хранилище загрузок
UPLOADS_ROOT=./uploads

# Telegram-уведомления об ошибках (опционально; пусто = не отправляем)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 2GIS API key (нужен мобильному приложению; бэк пробрасывает клиенту при необходимости)
TWOGIS_API_KEY=
